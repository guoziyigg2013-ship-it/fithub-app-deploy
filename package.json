{
  "name": "fithub-app-deploy",
  "private": true,
  "scripts": {
    "check:syntax": "node --check app.js && python3 -m py_compile server.py",
    "check:miniapp": "python3 scripts/check_miniprogram.py",
    "check:preflight": "python3 scripts/preflight_check.py",
    "check:production": "python3 scripts/production_readiness.py",
    "check:domestic": "python3 scripts/domestic_migration_status.py",
    "check:wechat-domains": "python3 scripts/wechat_domain_manifest.py",
    "check:production-write": "python3 scripts/production_write_acceptance.py",
    "config:production": "python3 scripts/configure_production.py",
    "init:tencent-env": "python3 scripts/init_tencent_env.py",
    "cutover:tencent": "python3 scripts/tencent_cutover.py",
    "release:tencent": "python3 scripts/build_tencent_release.py",
    "bootstrap:tencent-remote": "python3 scripts/tencent_remote_bootstrap.py",
    "deploy:tencent-remote": "python3 scripts/tencent_remote_deploy.py",
    "evidence:tencent-launch": "python3 scripts/tencent_launch_evidence.py",
    "check:tencent": "python3 scripts/tencent_cloud_preflight.py",
    "check:tencent-server": "python3 scripts/tencent_server_doctor.py",
    "check:smoke": "python3 scripts/deploy_smoke.py",
    "check:final": "python3 scripts/final_acceptance.py",
    "snapshot:prod": "python3 scripts/production_snapshot.py",
    "media:report": "python3 scripts/media_maintenance.py",
    "media:clean": "python3 scripts/media_maintenance.py --delete",
    "test:api": "python3 -m unittest discover -s tests/api -p 'test_*.py' -v",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1"
  }
}
