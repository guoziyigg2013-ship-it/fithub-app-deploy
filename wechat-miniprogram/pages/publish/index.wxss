.publish-card {
  margin-top: 34rpx;
}

.content-input {
  width: 100%;
  min-height: 260rpx;
  color: #171717;
  font-size: 30rpx;
  line-height: 1.6;
}

.media-preview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin: 18rpx 0;
}

.preview {
  width: 100%;
  height: 220rpx;
  border-radius: 24rpx;
  background: #eee;
}

.publish-button {
  margin-top: 30rpx;
}
