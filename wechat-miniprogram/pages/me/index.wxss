.profile-card {
  display: flex;
  gap: 22rpx;
  margin-top: 34rpx;
}

.big-avatar {
  width: 120rpx;
  height: 120rpx;
}

.profile-main {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.stats view {
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  background: #faf5ee;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.login-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 34rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 900;
}

.field {
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #efe6da;
  border-radius: 24rpx;
  background: #fff;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  gap: 14rpx;
}

.code-field {
  flex: 1;
}

.full {
  width: 100%;
}

.compliance-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.section-title {
  color: #171717;
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 6rpx;
}

.link-row,
.danger-row {
  min-height: 78rpx;
  padding: 0 24rpx;
  border: 0;
  border-radius: 22rpx;
  background: #faf5ee;
  color: #7c5a34;
  font-size: 28rpx;
  line-height: 78rpx;
  text-align: left;
}

.link-row::after,
.danger-row::after {
  border: 0;
}

.danger-row {
  background: #fff4ec;
  color: #d36b17;
}
