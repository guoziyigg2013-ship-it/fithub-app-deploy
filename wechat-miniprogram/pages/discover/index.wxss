.primary-small {
  min-width: 132rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffad42, #f47a10);
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
}

.recommend-scroll {
  width: 100%;
  white-space: nowrap;
}

.recommend-row {
  display: inline-flex;
  gap: 18rpx;
  padding-bottom: 8rpx;
}

.recommend-card {
  display: inline-flex;
  width: 214rpx;
  min-height: 318rpx;
  align-items: center;
  flex-direction: column;
  justify-content: space-between;
  padding: 26rpx 20rpx;
  white-space: normal;
}

.recommend-name {
  margin-top: 14rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.28;
  text-align: center;
}

.empty {
  color: #817872;
  font-size: 27rpx;
  line-height: 1.6;
}

.post {
  margin-bottom: 24rpx;
}

.post-head {
  gap: 18rpx;
}

.post-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.post-name {
  font-size: 29rpx;
  font-weight: 900;
}

.role {
  color: #171717;
  font-size: 24rpx;
  font-weight: 800;
}

.post-content {
  display: block;
  margin: 22rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.55;
}

.media-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.media {
  width: 100%;
  height: 220rpx;
  border-radius: 24rpx;
  background: #eee;
}

.action-row {
  display: flex;
  align-items: center;
  gap: 34rpx;
  margin-top: 20rpx;
}

.action-row button {
  color: #8a7968;
  font-size: 26rpx;
  font-weight: 800;
}
