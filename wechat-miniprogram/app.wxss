page {
  min-height: 100%;
  background: #fffaf4;
  color: #171717;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 36rpx 28rpx 48rpx;
}

.eyebrow {
  display: block;
  color: #9a9188;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.title {
  margin-top: 8rpx;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.05;
}

.section-title {
  margin: 36rpx 0 18rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.muted {
  color: #817872;
  font-size: 25rpx;
  line-height: 1.5;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff0df;
  color: #9f5d17;
  font-size: 24rpx;
  font-weight: 800;
}

.primary-button {
  min-height: 82rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffad42, #f47a10);
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 30rpx rgba(242, 124, 16, 0.22);
}

.ghost-button {
  min-height: 64rpx;
  padding: 0 24rpx;
  border: 2rpx solid #f5d1ad;
  border-radius: 999rpx;
  color: #9f5d17;
  font-size: 24rpx;
  font-weight: 800;
}

.card {
  padding: 28rpx;
  border: 2rpx solid #f0ebe5;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 46rpx rgba(61, 43, 24, 0.08);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #f1eee9;
}

.cover {
  width: 100%;
  height: 230rpx;
  border-radius: 28rpx;
  background: #f1eee9;
}

.row {
  display: flex;
  align-items: center;
}

.space-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
